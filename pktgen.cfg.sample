# =====================================================================
# Rocky Linux Packet Generator Configuration Template (Sample)
#
# 이 파일을 복사하여 'pktgen.cfg'로 이름을 변경하고 사용자 설정에 맞게 변경하여 사용하십시오.
# =====================================================================

[system]
# 패킷을 강제 송출할 리눅스 네트워크 인터페이스 카드 이름 (필수)
interface = enp0s3

# 초당 송출 패킷 수 (PPS) 제한 (0은 속도 제한 없이 시스템 최대 전송)
pps = 1000

# 시뮬레이션 가동 시간 (분 단위, 0은 무한 루프)
duration = 1


[user]
# 가상 User 노드들이 사용할 시작 IP 주소 / 서브넷 마스크
ip = 10.0.1.1/24
# 시뮬레이션할 가상 User 노드의 수
count = 100


[web]
# 가상 Web 서버 노드들이 사용할 시작 IP 주소 / 서브넷 마스크
ip = 10.0.2.1/24
# 시뮬레이션할 가상 Web 서버 노드의 수
count = 5


[was]
# 가상 WAS 서버 노드들이 사용할 시작 IP 주소 / 서브넷 마스크
ip = 10.0.3.1/24
# 시뮬레이션할 가상 WAS 서버 노드의 수
count = 2


[db]
# 가상 DB 서버 노드들이 사용할 시작 IP 주소 / 서브넷 마스크
ip = 10.0.4.1/24
# 시뮬레이션할 가상 DB 서버 노드의 수
count = 1


[data]
# 트랜잭션당 송출할 가상 데이터(Payload)의 최소 크기 (KB 단위, 소수점 지원)
min_kb = 2.0

# 트랜잭션당 송출할 가상 데이터(Payload)의 최대 크기 (KB 단위, 최대 10000.0 KB)
# 1.4 KB(MTU 한계)를 넘어가면 내부적으로 패킷이 분할 전송(TCP Segmentation)됩니다.
max_kb = 4.0

# 멀티스레드 병렬 전송 옵션 (true = 3개 스레드 병렬 구동, false = 싱글스레드 순차 구동)
use_thread = true

# =====================================================================
# Rocky Linux Packet Generator Configuration Template (Sample)
#
# 이 파일을 복사하여 'pktgen.cfg'로 이름을 변경하고 사용자 설정에 맞게 변경하여 사용하십시오.
# =====================================================================

[system]
interface = enp0s3      ; 패킷을 강제 송출할 리눅스 네트워크 인터페이스 카드 이름
pps = 1000              ; 초당 송출 패킷 수 (PPS) 제한 (0은 속도 제한 해제)
duration = 1            ; 시뮬레이션 가동 시간 (분 단위, 0은 무한 루프)
use_thread = true       ; 멀티스레드 병렬 전송 가동 여부 (true/false)

[data]
min_kb = 2.0            ; 트랜잭션당 송출할 가상 데이터(Payload)의 최소 크기 (KB)
max_kb = 4.0            ; 트랜잭션당 송출할 가상 데이터(Payload)의 최대 크기 (KB)

[user]
ip = 10.0.1.1/24        ; 가상 User 노드들이 사용할 시작 IP 주소 / CIDR
count = 100             ; 시뮬레이션할 가상 User 노드의 수

[web]
ip = 10.0.2.1/24        ; 가상 Web 서버 노드들이 사용할 시작 IP 주소 / CIDR
count = 5               ; 시뮬레이션할 가상 Web 서버 노드의 수

[was]
ip = 10.0.3.1/24        ; 가상 WAS 서버 노드들이 사용할 시작 IP 주소 / CIDR
count = 2               ; 시뮬레이션할 가상 WAS 서버 노드의 수

[db]
ip = 10.0.4.1/24        ; 가상 DB 서버 노드들이 사용할 시작 IP 주소 / CIDR
count = 1               ; 시뮬레이션할 가상 DB 서버 노드의 수
